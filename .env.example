# Set these in Railway → Project → Variables (do not commit real values)

PRIORITY_BASE=https://us.priority-connect.online/odata/Priority/tabc5eaa.ini/aa123
PRIORITY_USERNAME=your_priority_username_or_token
PRIORITY_PASSWORD=your_priority_password

# Fill this in once your Tally tunnel (Cloudflare Tunnel / Tailscale) is set up.
# Until then, Tally push/pull calls will fail with "connection refused" — expected,
# the app itself will still deploy and run fine.
TALLY_URL=https://tally.yourdomain.com
TALLY_COMPANY=Rishi's Test Zone
